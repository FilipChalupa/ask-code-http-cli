GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Read-only GitHub token for private repos (fine-grained PAT with Contents: read)
GITHUB_TOKEN=your-github-token-here

REPO_URL=https://github.com/your-org/your-repo.git

# Optional: Linear API key for project context (read-only Personal API key)
# Get it from: Linear Settings > API > Personal API keys
LINEAR_API_KEY=your-linear-api-key-here


HOST_PORT=3737

# Optional: enable verbose/debug output (0 = off, 1 = on)
VERBOSE=0

# Optional: enable shared memory so the AI can persist notes between queries (0 = off, 1 = on)
SHARED_MEMORY=0
