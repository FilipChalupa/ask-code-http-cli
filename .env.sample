GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Read-only GitHub token for private github.com repos (fine-grained PAT with Contents: read)
GITHUB_TOKEN=your-github-token-here

# Read-only Bitbucket token for private bitbucket.org repos
# (repository or workspace access token with Repositories: read)
# BITBUCKET_TOKEN=your-bitbucket-token-here

# One or more repositories the agent should look into.
# Separate multiple URLs with spaces, commas or newlines.
REPO_URLS=https://github.com/your-org/your-repo.git https://github.com/your-org/another-repo.git

# Legacy single-repo variable, still supported (used only if REPO_URLS is unset):
# REPO_URL=https://github.com/your-org/your-repo.git

# Optional: Linear API key for project context (read-only Personal API key)
# Get it from: Linear Settings > API > Personal API keys
LINEAR_API_KEY=your-linear-api-key-here

# Optional: Slack bot token - Slack permalinks in a question are expanded
# into the linked thread's content for context. Scopes: channels:history,
# users:read (+ groups:history for private channels). The bot must be a
# member of the linked channels.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here


HOST_PORT=3737

# Optional: enable verbose/debug output (0 = off, 1 = on)
VERBOSE=0
